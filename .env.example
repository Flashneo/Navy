# Required for AI scoring (pick one)
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Crunchbase for company size data
# CRUNCHBASE_API_KEY=your-crunchbase-key-here

# Telegram notifications (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# CORS origins (comma-separated, for production add your Vercel domain)
CORS_ORIGINS=http://localhost:3000,https://navyailinkedin.vercel.app
